.SILENT:

NAME    := binary_output_name
OUT_DIR ?= build
OUT     := $(OUT_DIR)/category_name
TARGET  := $(OUT)/$(NAME)
SRC     := $(wildcard *.go)

# --- Host OS & Architecture Detection ---
OS_NAME := $(shell uname -o 2>/dev/null || uname -s)
ARCH    := $(shell uname -m)

GO_ENV  :=

# --- HARDWARE OPTIMIZATION LAYER (Go Specific) ---
# Since the Go compiler does not have a built-in '-native' flag, it must be 
# perform manual probing to the OS level (/proc/cpuinfo) to assemble 
# appropriate microarchitectural instruction level.
ifeq ($(ARCH), x86_64)
    # PC/Server AMD64: SIMD instruction set injection/Vectorization
    HAS_AVX512 := $(shell grep -q avx512f /proc/cpuinfo 2>/dev/null && echo "yes" || echo "no")
    HAS_AVX2   := $(shell grep -q avx2 /proc/cpuinfo 2>/dev/null && echo "yes" || echo "no")

    ifeq ($(HAS_AVX512), yes)
        GO_ENV += GOAMD64=v4
    else ifeq ($(HAS_AVX2), yes)
        GO_ENV += GOAMD64=v3
    else
        GO_ENV += GOAMD64=v2
    endif
endif

# --- OS-SPECIFIC ADJUSTMENTS ---
ifeq ($(OS_NAME), Android)
    GO_ENV += CGO_ENABLED=0
endif

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(SRC)
	mkdir -p $(OUT)
	$(GO_ENV) go build -ldflags="-s -w" -o $(TARGET) .

clean:
	rm -rf $(OUT_DIR)
