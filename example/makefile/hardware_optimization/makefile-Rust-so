.SILENT:

RAW_NAME := name_in_lib
NAME     := binary_output_name.so
OUT_DIR  ?= build
OUT      := $(OUT_DIR)/category_name
TARGET   := $(OUT)/$(NAME)

# Cargo cache path resolution
CACHE    := $(CARGO_TARGET_DIR)
ifeq ($(CACHE),)
    CACHE := target
endif

# --- Host OS & Architecture Detection ---
ARCH     := $(shell uname -m)

# --- Hardware Optimization Layer ---
OPT_FLAGS :=

ifeq ($(ARCH), x86_64)
    # PC/Server AMD64: LLVM execution with host microarchitecture specific instructions.
    OPT_FLAGS := -C target-cpu=native
else ifeq ($(ARCH), aarch64)
    # Mobile/ARM64: Leave blank. LLVM will use generic ARM64 code-gen
    # to ensure a secure Application Binary Interface (ABI) across Android devices.
    OPT_FLAGS :=
endif

# Export RUSTFLAGS if target is not mobile/generic architecture
ifneq ($(OPT_FLAGS),)
    export RUSTFLAGS := $(OPT_FLAGS)
endif

SRC      := $(shell find src -name "*.rs" 2>/dev/null) Cargo.toml

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(SRC)
	mkdir -p $(OUT)
	cargo build --release --offline --quiet
	cp $(CACHE)/release/lib$(RAW_NAME).so $(TARGET)
	strip $(TARGET)

clean:
	cargo clean --quiet
	rm -f $(TARGET)
