NAME     := binary output name
OUT      := $(OUT_DIR)/category name
TARGET   := $(OUT)/$(NAME)
SOURCES  := $(wildcard *.c)

.PHONY: all clean
all: $(TARGET)

$(TARGET): $(SOURCES)
    @mkdir -p $(OUT)
    @LIBS=$$(grep -q "pcap.h" $(SOURCES) && echo "-lpcap" || echo ""); \
    gcc $(SOURCES) -o $(TARGET) $$LIBS

clean:
    rm -f $(TARGET)
